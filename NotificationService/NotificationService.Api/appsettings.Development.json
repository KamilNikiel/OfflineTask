{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "NotificationSettings": {
    "RetryPolicy": {
      "MaxRetries": 2,
      "BaseDelayMinutes": 0.5
    },
    "Providers": [
      {
        "Name": "Twilio",
        "Channel": "Sms",
        "IsEnabled": true,
        "Priority": 1
      },
      {
        "Name": "SendGrid",
        "Channel": "Email",
        "IsEnabled": true,
        "Priority": 1
      },
      {
        "Name": "Firebase",
        "Channel": "Push",
        "IsEnabled": true,
        "Priority": 1
      },
      {
        "Name": "AwsSns",
        "Channel": "Sms",
        "IsEnabled": true,
        "Priority": 2
      }
    ]
  }
}
